<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.*?>
<BorderPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
            fx:controller="pt.carguru.Controllers.ContaController"
            styleClass="root-bg" prefWidth="1200" prefHeight="760">
  <top>
    <HBox styleClass="navbar" alignment="CENTER_LEFT" spacing="4">
      <padding><Insets top="12" right="24" bottom="12" left="24"/></padding>
      <Button text="🚗 CarGuru" styleClass="nav-brand-btn" onAction="#irParaHome" focusTraversable="false"/>
      <Region HBox.hgrow="ALWAYS"/>
      <Button text="Dashboard" styleClass="nav-btn" onAction="#irParaDashboard" focusTraversable="false"/>
      <Button text="Veículos" styleClass="nav-btn" onAction="#irParaVeiculos" focusTraversable="false"/>
      <Button text="Reservas" styleClass="nav-btn" onAction="#irParaReservas" focusTraversable="false"/>
      <Button text="Conta" styleClass="nav-btn-active" focusTraversable="false" mouseTransparent="true"/>
      <Button fx:id="btnAdmin" text="🛡️ Admin" styleClass="nav-admin" onAction="#irParaAdmin" focusTraversable="false"/>
      <Button text="Logout" styleClass="nav-logout" onAction="#logout" focusTraversable="false"/>
    </HBox>
  </top>
  <center>
    <ScrollPane fitToWidth="true" styleClass="main-scroll">
      <VBox spacing="20" styleClass="page-content">
        <padding><Insets top="28" right="40" bottom="28" left="40"/></padding>

        <!-- Header perfil com avatar + foto -->
        <HBox spacing="20" alignment="CENTER_LEFT" styleClass="conta-header">
          <StackPane fx:id="avatarWrap" minWidth="72" minHeight="72" maxWidth="72" maxHeight="72">
            <Label fx:id="avatarLabel" text="??" styleClass="conta-avatar"/>
            <ImageView fx:id="avatarImage" fitWidth="72" fitHeight="72" preserveRatio="true"
                       visible="false" managed="false"/>
          </StackPane>
          <VBox spacing="4" HBox.hgrow="ALWAYS">
            <Label fx:id="nomeLabel" text="Nome" styleClass="conta-name"/>
            <Label fx:id="emailLabel" text="email" styleClass="conta-email"/>
            <Label fx:id="roleLabel" text="" styleClass="conta-role"/>
            <Label fx:id="avaliacaoLabel" text="Sem avaliações" styleClass="conta-email"/>
          </VBox>
          <Button text="📷 Alterar foto" styleClass="btn-outline-sm" onAction="#handleAlterarFoto"/>
        </HBox>

        <HBox spacing="20">
          <!-- Saldo -->
          <VBox styleClass="conta-card" spacing="12" HBox.hgrow="ALWAYS">
            <Label text="💶 Saldo em Conta" styleClass="conta-card-title"/>
            <Label fx:id="saldoLabel" text="0€" styleClass="saldo-val"/>
            <VBox spacing="2">
              <Label fx:id="caucaoLabel" text="🔒 Em caução: 0,00€" styleClass="conta-email"/>
              <Label fx:id="disponivelLabel" text="✅ Disponível: 0,00€" styleClass="conta-email"/>
            </VBox>
            <HBox spacing="10">
              <Button text="+ Depositar" styleClass="btn-depositar" onAction="#handleDepositar"
                      HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
              <Button text="- Levantar" styleClass="btn-levantar" onAction="#handleLevantar"
                      HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
            </HBox>
          </VBox>
          <!-- Perfil -->
          <VBox styleClass="conta-card" spacing="10" HBox.hgrow="ALWAYS">
            <Label text="👤 Perfil Pessoal" styleClass="conta-card-title"/>
            <Label text="Nome completo:" styleClass="form-label"/>
            <TextField fx:id="perfilNome" styleClass="form-input"/>
            <Label text="Email (não editável):" styleClass="form-label"/>
            <TextField fx:id="perfilEmail" styleClass="form-input" disable="true"/>
            <Label text="NIF:" styleClass="form-label"/>
            <TextField fx:id="perfilNif" styleClass="form-input"/>
            <Label fx:id="perfilErro" styleClass="error-label" wrapText="true"/>
            <Button text="Guardar alterações" styleClass="btn-auth" maxWidth="Infinity" onAction="#handleGuardarPerfil"/>
          </VBox>
        </HBox>

        <!-- Histórico de Transações -->
        <VBox styleClass="conta-card" spacing="10">
          <Label text="📜 Histórico de Transações" styleClass="conta-card-title"/>
          <Separator/>
          <VBox fx:id="transacoesList" spacing="6"/>
        </VBox>

        <!-- Carta de Condução -->
        <VBox styleClass="conta-card" spacing="10">
          <Label text="🪪 Carta de Condução" styleClass="conta-card-title"/>
          <HBox spacing="16">
            <VBox spacing="6" HBox.hgrow="ALWAYS">
              <Label text="Número da carta:" styleClass="form-label"/>
              <TextField fx:id="perfilNCarta" promptText="Ex: S-123456-7" styleClass="form-input"/>
            </VBox>
            <VBox spacing="6" HBox.hgrow="ALWAYS">
              <Label text="Validade:" styleClass="form-label"/>
              <DatePicker fx:id="perfilValidadeCarta" styleClass="form-input" maxWidth="Infinity"/>
            </VBox>
          </HBox>
          <Label fx:id="cartaErro" styleClass="error-label" wrapText="true"/>
          <Button text="Guardar carta de condução" styleClass="btn-auth" maxWidth="Infinity" onAction="#handleGuardarCarta"/>
        </VBox>

        <!-- Veículos -->
        <VBox styleClass="conta-card" spacing="12">
          <HBox alignment="CENTER_LEFT" spacing="16">
            <Label text="🚗 Os meus veículos" styleClass="conta-card-title" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
            <Button text="+ Adicionar veículo" styleClass="btn-primary" onAction="#handleAdicionarVeiculo"/>
          </HBox>
          <Separator/>
          <VBox fx:id="veiculosList" spacing="8"/>
        </VBox>

      </VBox>
    </ScrollPane>
  </center>
</BorderPane>
