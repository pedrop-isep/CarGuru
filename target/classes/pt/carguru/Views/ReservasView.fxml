<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>
<BorderPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
            fx:controller="pt.carguru.Controllers.ReservasController"
            styleClass="root-bg" prefWidth="1200" prefHeight="760">
  <top>
    <HBox styleClass="navbar" alignment="CENTER_LEFT" spacing="4">
      <padding><Insets top="12" right="24" bottom="12" left="24"/></padding>
      <Button text="🚗 CarGuru" styleClass="nav-brand-btn" onAction="#irParaHome" focusTraversable="false"/>
      <Region HBox.hgrow="ALWAYS"/>
      <Button text="Dashboard" styleClass="nav-btn" onAction="#irParaDashboard" focusTraversable="false"/>
      <Button text="Veículos" styleClass="nav-btn" onAction="#irParaVeiculos" focusTraversable="false"/>
      <Button text="Reservas" styleClass="nav-btn-active" focusTraversable="false" mouseTransparent="true"/>
      <Button text="Conta" styleClass="nav-btn" onAction="#irParaConta" focusTraversable="false"/>
      <Button fx:id="btnAdmin" text="🛡️ Admin" styleClass="nav-admin" onAction="#irParaAdmin" focusTraversable="false"/>
      <Button text="Logout" styleClass="nav-logout" onAction="#logout" focusTraversable="false"/>
    </HBox>
  </top>
  <center>
    <ScrollPane fitToWidth="true" styleClass="main-scroll">
      <VBox spacing="24" styleClass="page-content">
        <padding><Insets top="28" right="40" bottom="28" left="40"/></padding>
        <Label text="📅 As minhas reservas" styleClass="page-title"/>
        <TabPane styleClass="reservas-tabs" tabClosingPolicy="UNAVAILABLE">
          <!-- Locatário -->
          <Tab text="Como Locatário">
            <ScrollPane fitToWidth="true" styleClass="main-scroll" prefHeight="500">
              <VBox fx:id="reservasLocatarioList" spacing="12">
                <padding><Insets top="16" right="4" bottom="16" left="4"/></padding>
              </VBox>
            </ScrollPane>
          </Tab>
          <!-- Proprietário -->
          <Tab text="Como Proprietário">
            <ScrollPane fitToWidth="true" styleClass="main-scroll" prefHeight="500">
              <VBox fx:id="reservasProprietarioList" spacing="12">
                <padding><Insets top="16" right="4" bottom="16" left="4"/></padding>
              </VBox>
            </ScrollPane>
          </Tab>
        </TabPane>
      </VBox>
    </ScrollPane>
  </center>
</BorderPane>
