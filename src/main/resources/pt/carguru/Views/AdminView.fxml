<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>
<BorderPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
            fx:controller="pt.carguru.Controllers.AdminController"
            styleClass="root-bg" prefWidth="1200" prefHeight="760">
  <top>
    <HBox styleClass="navbar" alignment="CENTER_LEFT" spacing="4">
      <padding><Insets top="12" right="24" bottom="12" left="24"/></padding>
      <Button text="🚗 CarGuru" styleClass="nav-brand-btn" onAction="#irParaHome" focusTraversable="false"/>
      <Label text="  🛡️ Painel Admin" style="-fx-text-fill:#dc2626; -fx-font-size:0.85em;"/>
      <Region HBox.hgrow="ALWAYS"/>
      <Button text="Dashboard" styleClass="nav-btn" onAction="#irParaDashboard" focusTraversable="false"/>
      <Button text="Veículos" styleClass="nav-btn" onAction="#irParaVeiculos" focusTraversable="false"/>
      <Button text="Reservas" styleClass="nav-btn" onAction="#irParaReservas" focusTraversable="false"/>
      <Button text="Conta" styleClass="nav-btn" onAction="#irParaConta" focusTraversable="false"/>
      <Button text="🛡️ Admin" styleClass="nav-btn-active" focusTraversable="false" mouseTransparent="true"/>
      <Button text="Logout" styleClass="nav-logout" onAction="#logout" focusTraversable="false"/>
    </HBox>
  </top>
  <center>
    <ScrollPane fitToWidth="true" styleClass="main-scroll">
      <VBox spacing="24" styleClass="page-content">
        <padding><Insets top="28" right="40" bottom="28" left="40"/></padding>
        <Label text="🛡️ Painel de Administração" styleClass="page-title"/>

        <TabPane tabClosingPolicy="UNAVAILABLE">

          <!-- Veículos pendentes -->
          <Tab text="⏳ Veículos Pendentes">
            <ScrollPane fitToWidth="true" styleClass="main-scroll" prefHeight="580">
              <VBox spacing="12">
                <padding><Insets top="16" right="4" bottom="16" left="4"/></padding>
                <Label text="Veículos a aguardar validação" styleClass="admin-section-title"/>
                <VBox fx:id="veiculosPendentesList" spacing="8"/>
              </VBox>
            </ScrollPane>
          </Tab>

          <!-- Todos os veículos -->
          <Tab text="🚗 Todos os Veículos">
            <ScrollPane fitToWidth="true" styleClass="main-scroll" prefHeight="580">
              <VBox spacing="12">
                <padding><Insets top="16" right="4" bottom="16" left="4"/></padding>
                <Label text="Todos os veículos na plataforma" styleClass="admin-section-title"/>
                <VBox fx:id="todosVeiculosList" spacing="8"/>
              </VBox>
            </ScrollPane>
          </Tab>

          <!-- Utilizadores -->
          <Tab text="👥 Utilizadores">
            <ScrollPane fitToWidth="true" styleClass="main-scroll" prefHeight="580">
              <VBox spacing="12">
                <padding><Insets top="16" right="4" bottom="16" left="4"/></padding>
                <Label text="Gestão de utilizadores" styleClass="admin-section-title"/>
                <VBox fx:id="utilizadoresList" spacing="8"/>
              </VBox>
            </ScrollPane>
          </Tab>

          <!-- Histórico reservas -->
          <Tab text="📋 Histórico Reservas">
            <ScrollPane fitToWidth="true" styleClass="main-scroll" prefHeight="580">
              <VBox spacing="12">
                <padding><Insets top="16" right="4" bottom="16" left="4"/></padding>
                <Label text="Histórico global de reservas" styleClass="admin-section-title"/>
                <VBox fx:id="historicoList" spacing="6"/>
              </VBox>
            </ScrollPane>
          </Tab>

          <!-- Disputas de caução -->
          <Tab text="⚖️ Disputas de Caução">
            <ScrollPane fitToWidth="true" styleClass="main-scroll" prefHeight="580">
              <VBox spacing="12">
                <padding><Insets top="16" right="4" bottom="16" left="4"/></padding>
                <Label text="Disputas de caução pendentes e resolvidas" styleClass="admin-section-title"/>
                <VBox fx:id="disputasList" spacing="10"/>
              </VBox>
            </ScrollPane>
          </Tab>

        </TabPane>
      </VBox>
    </ScrollPane>
  </center>
</BorderPane>
