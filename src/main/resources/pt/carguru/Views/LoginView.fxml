<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>
<BorderPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
            fx:controller="pt.carguru.Controllers.AuthController"
            styleClass="root-bg" prefWidth="1200" prefHeight="760">

  <!-- Top bar pública -->
  <top>
    <HBox styleClass="navbar" alignment="CENTER_LEFT" spacing="8">
      <padding><Insets top="12" right="28" bottom="12" left="28"/></padding>
      <Button text="🚗 CarGuru" styleClass="nav-brand-btn" onAction="#irParaHome" focusTraversable="false"/>
      <Region HBox.hgrow="ALWAYS"/>
      <Button text="Entrar" styleClass="btn-outline-sm" onAction="#irParaHome"/>
      <Button text="Registar" styleClass="btn-primary" onAction="#irParaHome"/>
    </HBox>
  </top>

  <center>
    <VBox alignment="CENTER" styleClass="root-bg">
      <padding><Insets top="40" right="40" bottom="40" left="40"/></padding>

      <!-- Logo -->
      <VBox alignment="CENTER" spacing="4" style="-fx-padding:0 0 20 0;">
        <Label text="🚗" style="-fx-font-size:2.6em;"/>
        <HBox alignment="CENTER">
          <Label text="Car" styleClass="logo-full"/>
          <Label text="Guru" styleClass="logo-full logo-accent"/>
        </HBox>
        <Label text="Aluguer peer-to-peer de veículos" style="-fx-text-fill:#666; -fx-font-size:0.85em;"/>
      </VBox>

      <!-- TabPane Auth -->
      <TabPane styleClass="auth-tabpane" tabClosingPolicy="UNAVAILABLE" maxWidth="520">
        <Tab text="Entrar">
          <VBox styleClass="auth-form" spacing="14">
            <padding><Insets top="24" right="32" bottom="24" left="32"/></padding>
            <Label text="Email:" styleClass="form-label"/>
            <TextField fx:id="loginEmail" styleClass="form-input" promptText="email@exemplo.com"/>
            <Label text="Password:" styleClass="form-label"/>
            <PasswordField fx:id="loginPassword" styleClass="form-input" promptText="A tua password"/>
            <Label fx:id="loginErro" styleClass="error-label" wrapText="true"/>
            <Button text="Entrar →" styleClass="btn-auth" maxWidth="Infinity" onAction="#handleLogin"/>
          </VBox>
        </Tab>

        <Tab text="Registar">
          <ScrollPane fitToWidth="true" styleClass="main-scroll" prefHeight="440">
            <VBox styleClass="auth-form" spacing="12">
              <padding><Insets top="20" right="32" bottom="24" left="32"/></padding>
              <Label text="Nome completo:" styleClass="form-label"/>
              <TextField fx:id="regNome" styleClass="form-input" promptText="O teu nome"/>
              <Label fx:id="regNomeErro" styleClass="field-error-label" wrapText="true" managed="false" visible="false"/>
              <Label text="Email:" styleClass="form-label"/>
              <TextField fx:id="regEmail" styleClass="form-input" promptText="email@exemplo.com"/>
              <Label fx:id="regEmailErro" styleClass="field-error-label" wrapText="true" managed="false" visible="false"/>
              <Label text="Password:" styleClass="form-label"/>
              <PasswordField fx:id="regPassword" styleClass="form-input" promptText="Mínimo 6 caracteres"/>
              <Label fx:id="regPasswordErro" styleClass="field-error-label" wrapText="true" managed="false" visible="false"/>
              <Label text="Confirmar password:" styleClass="form-label"/>
              <PasswordField fx:id="regConfirmPassword" styleClass="form-input" promptText="Repete a password"/>
              <Label fx:id="regConfirmPasswordErro" styleClass="field-error-label" wrapText="true" managed="false" visible="false"/>
              <Label text="NIF (9 dígitos):" styleClass="form-label"/>
              <TextField fx:id="regNif" styleClass="form-input" promptText="123456789"/>
              <Label fx:id="regNifErro" styleClass="field-error-label" wrapText="true" managed="false" visible="false"/>
              <Label text="Nº Carta de condução:" styleClass="form-label"/>
              <TextField fx:id="regCarta" styleClass="form-input" promptText="Número da carta"/>
              <Label fx:id="regCartaErro" styleClass="field-error-label" wrapText="true" managed="false" visible="false"/>
              <Label text="Validade da carta:" styleClass="form-label"/>
              <DatePicker fx:id="regValidadeCarta" maxWidth="Infinity"/>
              <Label fx:id="regValidadeCartaErro" styleClass="field-error-label" wrapText="true" managed="false" visible="false"/>
              <Label fx:id="regErro" styleClass="error-label" wrapText="true"/>
              <Button text="Criar conta →" styleClass="btn-auth" maxWidth="Infinity" onAction="#handleRegistar"/>
            </VBox>
          </ScrollPane>
        </Tab>

        <Tab text="Recuperar password">
          <VBox styleClass="auth-form" spacing="12">
            <padding><Insets top="20" right="32" bottom="24" left="32"/></padding>
            <Label fx:id="recMensagem" styleClass="success-label" wrapText="true"/>
            <VBox fx:id="recPhase1" spacing="10">
              <Label text="Email da conta:" styleClass="form-label"/>
              <TextField fx:id="recEmail" styleClass="form-input" promptText="email@exemplo.com"/>
              <Button text="Enviar token →" styleClass="btn-auth" maxWidth="Infinity" onAction="#handleEnviarToken"/>
            </VBox>
            <VBox fx:id="recPhase2" spacing="10">
              <Label text="Token recebido:" styleClass="form-label"/>
              <TextField fx:id="recToken" styleClass="form-input" promptText="Cola o token aqui"/>
              <Label text="Nova password:" styleClass="form-label"/>
              <PasswordField fx:id="recNovaPw" styleClass="form-input" promptText="Mínimo 6 caracteres"/>
              <Label text="Confirmar password:" styleClass="form-label"/>
              <PasswordField fx:id="recConfirmPw" styleClass="form-input" promptText="Repete a password"/>
              <Button text="Redefinir password →" styleClass="btn-auth" maxWidth="Infinity" onAction="#handleRedefinirPassword"/>
            </VBox>
            <Label fx:id="recErro" styleClass="error-label" wrapText="true"/>
          </VBox>
        </Tab>
      </TabPane>

    </VBox>
  </center>
</BorderPane>
