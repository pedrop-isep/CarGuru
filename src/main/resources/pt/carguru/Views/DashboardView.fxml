<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>
<BorderPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
            fx:controller="pt.carguru.Controllers.DashboardController"
            styleClass="root-bg" prefWidth="1200" prefHeight="760">
  <top>
    <HBox styleClass="navbar" alignment="CENTER_LEFT" spacing="4">
      <padding><Insets top="12" right="24" bottom="12" left="24"/></padding>
      <Button text="🚗 CarGuru" styleClass="nav-brand-btn" onAction="#irParaHome" focusTraversable="false"/>
      <Region HBox.hgrow="ALWAYS"/>
      <Button text="Dashboard" styleClass="nav-btn-active" focusTraversable="false" mouseTransparent="true"/>
      <Button text="Veículos" styleClass="nav-btn" onAction="#irParaVeiculos" focusTraversable="false"/>
      <Button text="Reservas" styleClass="nav-btn" onAction="#irParaReservas" focusTraversable="false"/>
      <Button text="Conta" styleClass="nav-btn" onAction="#irParaConta" focusTraversable="false"/>
      <Button fx:id="btnAdmin" text="🛡️ Admin" styleClass="nav-admin" onAction="#irParaAdmin" focusTraversable="false"/>
      <Button text="Logout" styleClass="nav-logout" onAction="#logout" focusTraversable="false"/>
    </HBox>
  </top>
  <center>
    <ScrollPane fitToWidth="true" styleClass="main-scroll">
      <VBox spacing="24" styleClass="page-content">
        <padding><Insets top="32" right="40" bottom="32" left="40"/></padding>
        <Label fx:id="nomeLabel" styleClass="page-title" text="BEM-VINDO!"/>
        <HBox spacing="16">
          <VBox styleClass="stat-card" HBox.hgrow="ALWAYS" alignment="CENTER" spacing="6">
            <Label text="🚗" styleClass="stat-icon"/>
            <Label fx:id="totalVeiculosLabel" text="0" styleClass="stat-val"/>
            <Label text="Os meus veículos" styleClass="stat-label"/>
          </VBox>
          <VBox styleClass="stat-card" HBox.hgrow="ALWAYS" alignment="CENTER" spacing="6">
            <Label text="📅" styleClass="stat-icon"/>
            <Label fx:id="reservasAtivasLabel" text="0" styleClass="stat-val"/>
            <Label text="Reservas ativas" styleClass="stat-label"/>
          </VBox>
          <VBox styleClass="stat-card" HBox.hgrow="ALWAYS" alignment="CENTER" spacing="6">
            <Label text="💶" styleClass="stat-icon"/>
            <Label fx:id="saldoLabel" text="0€" styleClass="stat-val"/>
            <Label text="Saldo em conta" styleClass="stat-label"/>
          </VBox>
        </HBox>
        <HBox spacing="20">
          <VBox styleClass="dash-card" HBox.hgrow="ALWAYS" spacing="12">
            <HBox alignment="CENTER_LEFT" spacing="12">
              <Label text="🚗 Os meus veículos" styleClass="dash-card-title" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
              <Button text="Gerir →" styleClass="btn-outline-sm" onAction="#irParaConta"/>
            </HBox>
            <Separator/>
            <VBox fx:id="veiculosBox" spacing="6"/>
          </VBox>
          <VBox styleClass="dash-card" HBox.hgrow="ALWAYS" spacing="12">
            <HBox alignment="CENTER_LEFT" spacing="12">
              <Label text="📅 Últimas reservas" styleClass="dash-card-title" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
              <Button text="Ver todas →" styleClass="btn-outline-sm" onAction="#irParaReservas"/>
            </HBox>
            <Separator/>
            <VBox fx:id="reservasBox" spacing="6"/>
          </VBox>
        </HBox>
      </VBox>
    </ScrollPane>
  </center>
</BorderPane>
